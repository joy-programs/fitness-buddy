# ─────────────────────────────────────────────────────────────
#  IBM watsonx.ai credentials
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────

# IBM Cloud API Key
# Get it from: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_cloud_api_key_here

# watsonx.ai Project ID
# Find it in your watsonx.ai project settings page
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai Service URL (region-specific)
# Default for Dallas region (us-south) — change if your instance is in a different region
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM Granite Model ID
# Using ibm/granite-4-h-small — available on Lite plan (us-south)
GRANITE_MODEL_ID=ibm/granite-4-h-small

# ─────────────────────────────────────────────────────────────
#  Application Settings
# ─────────────────────────────────────────────────────────────

# FastAPI host and port (used for CORS allowlist)
APP_HOST=localhost
APP_PORT=8000

# Set to "development" locally, "production" on deployment
APP_ENV=development
